# Core
MONGODB_URI=
APP_BASE_URL=http://localhost:3000

# LIFF (player) — exposed to browser
NEXT_PUBLIC_LIFF_ID=
# Mirror of LINE_BOT_BASIC_ID — exposed to browser for add-friend link
NEXT_PUBLIC_LINE_BOT_BASIC_ID=

# LINE Login (admin OAuth)
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# Optional comma-separated lineUserId allowlist. Leave empty to let the first LINE login
# become admin automatically (saved to the Admin collection); set it to pre-authorize
# admins or as a permanent break-glass override.
ADMIN_LINE_IDS=
ADMIN_SESSION_SECRET=

# LINE Messaging API (push)
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_BOT_BASIC_ID=

# DigitalOcean Spaces (S3-compatible)
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=
SPACES_CDN_BASE_URL=

# Cron
CRON_SECRET=
